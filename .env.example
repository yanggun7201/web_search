# Server
PORT=8789
API_KEY=                    # Token auth; leave empty to disable

# SearXNG
SEARXNG_URL=http://localhost:8888

# Search
FETCH_CONTENT=false         # true: fetch full article text via Readability
CACHE_TTL_MIN=5

# Collector (news auto-collection)
CRON_SCHEDULE=0 7 * * *
CRON_TZ=Pacific/Auckland
# RAW_PATH=./state/technews_step1_raw_urls.json
# SELECTED_PATH=./state/technews_step2_selected.json
# PER_KEYWORD=5
# PER_CATEGORY=5
# KEYWORDS=Anthropic latest news,Claude AI model update
